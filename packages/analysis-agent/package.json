{
  "name": "@codebase-analysis/agent",
  "version": "1.0.0",
  "description": "Codebase analysis and refactoring skills for Claude Code and GitHub Copilot - find duplicate code, dead code, and architecture violations",
  "main": "agents/codebase-analysis.md",
  "type": "module",
  "bin": {
    "codebase-analysis": "./cli.cjs"
  },
  "scripts": {
    "setup": "bash scripts/setup.sh",
    "analyze:all": "bash scripts/run-analysis.sh",
    "analyze:dead": "knip",
    "analyze:dupes": "jscpd src",
    "analyze:deps": "depcruise src --config templates/.dependency-cruiser.cjs --output-type err"
  },
  "skills": [
    "skills/duplicate-detection/SKILL.md",
    "skills/dead-code-analysis/SKILL.md",
    "skills/analysis-orchestrator/SKILL.md"
  ],
  "files": [
    "agents",
    "skills",
    "templates",
    "scripts",
    "cli.cjs"
  ],
  "keywords": [
    "claude",
    "claude-code",
    "copilot",
    "github-copilot",
    "agent",
    "code-analysis",
    "refactoring",
    "dead-code",
    "duplicate-detection",
    "architecture",
    "monorepo"
  ],
  "author": "kylebrodeur",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/kylebrodeur/codebase-analysis.git"
  },
  "bugs": {
    "url": "https://github.com/kylebrodeur/codebase-analysis/issues"
  },
  "homepage": "https://github.com/kylebrodeur/codebase-analysis#readme"
}
